import { query } from '../config/db';

export class SlotGenerator {

  static async getAvailableSlots(
    salon_id: string,
    service_id: string,
    date: string
  ) {

    const serviceRes = await query(
      `SELECT id, duration_minutes FROM services WHERE id = $1 AND salon_id = $2`,
      [service_id, salon_id]
    );

    if (serviceRes.rows.length === 0) return [];

    const duration = serviceRes.rows[0].duration_minutes;

    const staffRes = await query(
      `SELECT s.id, s.full_name
       FROM staff s
       JOIN service_staff ss ON ss.staff_id = s.id
       WHERE ss.service_id = $1 AND ss.salon_id = $2`,
      [service_id, salon_id]
    );

    const staffList = staffRes.rows;

    const slots: any[] = [];

    for (const staff of staffList) {

      const hoursRes = await query(
        `SELECT start_time, end_time
         FROM staff_working_hours
         WHERE staff_id = $1
         AND salon_id = $2
         AND weekday = EXTRACT(DOW FROM $3::date)
         AND is_active = TRUE`,
        [staff.id, salon_id, date]
      );

      if (hoursRes.rows.length === 0) continue;

      const apptRes = await query(
        `SELECT appointment_time, duration_minutes
         FROM appointments
         WHERE staff_id = $1
         AND DATE(appointment_time) = $2
         AND status IN ('SCHEDULED','IN_PROGRESS')`,
        [staff.id, date]
      );

      const breakRes = await query(
        `SELECT start_time, end_time
         FROM staff_breaks
         WHERE staff_id = $1
         AND salon_id = $2
         AND weekday = EXTRACT(DOW FROM $3::date)`,
        [staff.id, salon_id, date]
      );

      const timeOffRes = await query(
        `SELECT start_datetime, end_datetime
         FROM staff_time_off
         WHERE staff_id = $1
         AND salon_id = $2
         AND DATE(start_datetime) <= $3
         AND DATE(end_datetime) >= $3`,
        [staff.id, salon_id, date]
      );

      const blocked: { start: number; end: number }[] = [];

      for (const a of apptRes.rows) {
        const start = new Date(a.appointment_time).getTime();
        const end = start + a.duration_minutes * 60000;
        blocked.push({ start, end });
      }

      for (const b of breakRes.rows) {
        const start = new Date(`${date}T${b.start_time}`).getTime();
        const end = new Date(`${date}T${b.end_time}`).getTime();
        blocked.push({ start, end });
      }

      for (const t of timeOffRes.rows) {
        blocked.push({
          start: new Date(t.start_datetime).getTime(),
          end: new Date(t.end_datetime).getTime()
        });
      }

      for (const window of hoursRes.rows) {

        const start = new Date(`${date}T${window.start_time}`);
        const end = new Date(`${date}T${window.end_time}`);

        let current = new Date(start);

        while (current.getTime() + duration * 60000 <= end.getTime()) {

          const slotStart = current.getTime();
          const slotEnd = slotStart + duration * 60000;

          const conflict = blocked.some(b =>
            slotStart < b.end && slotEnd > b.start
          );

          if (!conflict) {
            slots.push({
              staff_id: staff.id,
              staff_name: staff.full_name,
              time: current.toISOString()
            });
          }

          current = new Date(current.getTime() + 10 * 60000);
        }
      }
    }

    return slots.sort((a, b) => new Date(a.time).getTime() - new Date(b.time).getTime());
  }
}
